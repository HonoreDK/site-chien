    <div class="ip-actions">
      <button class="btn btn-primary" id="installYes">Installer</button>
      <button class="btn ip-later" id="installLater">Plus tard</button>
    </div>
  </div>
</div>

<script>
/* ============================================================
   Stockage tolérant : fonctionne en site hébergé,
   ne plante jamais dans un environnement sans localStorage.
   ============================================================ */
const store = {
  get(k){ try{ return localStorage.getItem(k); }catch(e){ return null; } },
  set(k,v){ try{ localStorage.setItem(k,v); }catch(e){} }
};

/* ===== Thème clair / sombre ===== */
const root = document.documentElement;
const savedTheme = store.get('theme');
if(savedTheme){ root.setAttribute('data-theme', savedTheme); }
else if(window.matchMedia('(prefers-color-scheme: dark)').matches){ root.setAttribute('data-theme','dark'); }
document.getElementById('themeBtn').addEventListener('click', ()=>{
  const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
  root.setAttribute('data-theme', next);
  store.set('theme', next);
  document.querySelector('meta[name=theme-color]').setAttribute('content', next==='dark' ? '#0B1120' : '#FF7A59');
});

/* ===== Navbar : état au scroll + menu mobile ===== */
const nav = document.getElementById('nav');
const navLinks = document.getElementById('navLinks');
addEventListener('scroll', ()=> nav.classList.toggle('scrolled', scrollY > 24), {passive:true});
document.getElementById('burger').addEventListener('click', ()=> navLinks.classList.toggle('open'));
navLinks.querySelectorAll('a').forEach(a=> a.addEventListener('click', ()=> navLinks.classList.remove('open')));

/* ===== Parallaxe douce du visuel hero ===== */
const heroVisual = document.getElementById('heroVisual');
addEventListener('scroll', ()=>{
  if(scrollY < 700 && !matchMedia('(prefers-reduced-motion:reduce)').matches){
    heroVisual.style.transform = `translateY(${scrollY * 0.06}px)`;
  }
}, {passive:true});

/* ===== Données animaux ===== */
const pets = [
  { id:'luna', name:'Luna', type:'dog', age:'2 ans', sex:'Femelle', breed:'Border Collie', price:'80€', status:'dispo',
    health:'Vaccinée & stérilisée', vax:['Vaccins à jour','Stérilisée','Pucée','Vermifugée'],
    desc:"Luna déborde d'énergie et adore courir. Très intelligente, elle apprend vite et cherche une famille active qui saura canaliser son enthousiasme avec de belles balades.",
    history:"Arrivée après le déménagement de ses anciens maîtres. Sociable avec les autres chiens.",
    imgs:['https://images.unsplash.com/photo-1503256207526-0d5d80fa2f47?auto=format&fit=crop&w=900&q=80','https://images.unsplash.com/photo-1605897472359-85e4b94d685d?auto=format&fit=crop&w=600&q=80','https://images.unsplash.com/photo-1518717758536-85ae29035b6d?auto=format&fit=crop&w=600&q=80'] },
  { id:'milo', name:'Milo', type:'cat', age:'1 an', sex:'Mâle', breed:'Européen', price:'60€', status:'new',
    health:'Vacciné, à stériliser', vax:['Vaccins à jour','Pucé','Testé FIV/FeLV','Vermifugé'],
    desc:"Milo est un jeune chat câlin et curieux. Il ronronne dès qu'on l'approche et adore les rebords de fenêtre ensoleillés. Parfait pour une première adoption.",
    history:"Trouvé seul, sevré et élevé au refuge. Propre et très affectueux.",
    imgs:['https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&w=900&q=80','https://images.unsplash.com/photo-1495360010541-f48722b34f7d?auto=format&fit=crop&w=600&q=80','https://images.unsplash.com/photo-1573865526739-10659fec78a5?auto=format&fit=crop&w=600&q=80'] },
  { id:'pepite', name:'Pépite', type:'dog', age:'4 mois', sex:'Femelle', breed:'Croisée Labrador', price:'50€', status:'new',
    health:'Première vaccination', vax:['Primo-vaccination','Pucée','Vermifugée'],
    desc:"Une petite boule de poils joueuse qui découvre le monde. Pépite cherche une famille patiente pour l'accompagner dans son éducation et ses premières aventures.",
    history:"Née au refuge d'une chienne recueillie gestante. Sociable et gourmande.",
    imgs:['https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?auto=format&fit=crop&w=900&q=80','https://images.unsplash.com/photo-1591160690555-5debfba289f0?auto=format&fit=crop&w=600&q=80','https://images.unsplash.com/photo-1537151625747-768eb6cf92b2?auto=format&fit=crop&w=600&q=80'] },
  { id:'tigrou', name:'Tigrou', type:'cat', age:'3 mois', sex:'Mâle', breed:'Tigré', price:'40€', status:'new',
    health:'Vacciné, à stériliser', vax:['Primo-vaccination','Pucé','Vermifugé'],
    desc:"Tigrou est un chaton espiègle qui passe son temps à jouer puis à s'endormir n'importe où. Plein de vie, il s'entend très bien avec les autres chats.",
    history:"Recueilli avec sa fratrie, désormais prêt à rejoindre son foyer.",
    imgs:['https://images.unsplash.com/photo-1574144611937-0df059b5ef3e?auto=format&fit=crop&w=900&q=80','https://images.unsplash.com/photo-1592194996308-7b43878e84a6?auto=format&fit=crop&w=600&q=80','https://images.unsplash.com/photo-1596854407944-bf87f6fdd49e?auto=format&fit=crop&w=600&q=80'] },
  { id:'rocky', name:'Rocky', type:'dog', age:'5 ans', sex:'Mâle', breed:'Berger Allemand', price:'80€', status:'reserve',
    health:'Vacciné & pucé', vax:['Vaccins à jour','Stérilisé','Pucé'],
    desc:"Rocky est un compagnon loyal et posé. Très attaché à l'humain, il rêve d'un jardin et d'une famille qui lui offrira de longues promenades tranquilles.",
    history:"Confié au refuge faute de temps de ses maîtres. Doux et obéissant.",
    imgs:['https://images.unsplash.com/photo-1589941013453-ec89f33b5e95?auto=format&fit=crop&w=900&q=80','https://images.unsplash.com/photo-1551717743-49959800b1f6?auto=format&fit=crop&w=600&q=80','https://images.unsplash.com/photo-1568572933382-74d440642117?auto=format&fit=crop&w=600&q=80'] },
  { id:'nala', name:'Nala', type:'cat', age:'3 ans', sex:'Femelle', breed:'Maine Coon croisé', price:'60€', status:'dispo',
    health:'Vaccinée & stérilisée', vax:['Vaccins à jour','Stérilisée','Pucée','Testée FIV/FeLV'],
    desc:"Nala est une chatte majestueuse et indépendante, qui aime sa tranquillité autant qu'un bon câlin du soir. Idéale pour un foyer calme.",
    history:"Abandonnée lors d'un déménagement. Pleine de douceur une fois en confiance.",
    imgs:['https://images.unsplash.com/photo-1518791841217-8f162f1e1131?auto=format&fit=crop&w=900&q=80','https://images.unsplash.com/photo-1533738363-b7f9aef128ce?auto=format&fit=crop&w=600&q=80','https://images.unsplash.com/photo-1561948955-570b270e7c36?auto=format&fit=crop&w=600&q=80'] },
];

const statusMap = {
  dispo:   {cls:'b-dispo',   label:'Disponible'},
  reserve: {cls:'b-reserve', label:'Réservé'},
  new:     {cls:'b-nouveau', label:'Nouveau'},
};

/* Image de secours si une photo ne charge pas */
function imgFallback(el){
  el.onerror = null;
  el.style.display = 'none';
  el.parentElement.style.display = 'grid';
  el.parentElement.style.placeItems = 'center';
  if(!el.parentElement.querySelector('.ph')){
    const s = document.createElement('div');
    s.className = 'ph'; s.style.fontSize = '3rem'; s.textContent = '🐾';
    el.parentElement.appendChild(s);
  }
}

/* ===== Rendu des cartes ===== */
const grid = document.getElementById('petGrid');
function renderPets(filter='all'){
  grid.innerHTML = '';
  pets.filter(p => filter==='all' ? true : filter==='new' ? p.status==='new' : p.type===filter)
      .forEach((p, i)=>{
    const st = statusMap[p.status];
    const card = document.createElement('article');
    card.className = 'pet-card reveal';
    card.dataset.d = (i % 4) + 1;
    card.innerHTML = `
      <div class="pet-media">
        <span class="pet-badge ${st.cls}">${st.label}</span>
        <button class="pet-fav" aria-label="Ajouter aux favoris" onclick="event.stopPropagation(); this.classList.toggle('on')">
          <svg viewBox="0 0 24 24"><path d="M12 21s-7-4.5-9.5-9C.7 8.4 2.3 5 5.6 5c1.9 0 3.2 1.1 4.4 2.5C11.2 6.1 12.5 5 14.4 5c3.3 0 4.9 3.4 3.1 7-2.5 4.5-9.5 9-9.5 9z"/></svg>
        </button>
        <img src="${p.imgs[0]}" alt="${p.name}" loading="lazy" onerror="imgFallback(this)">
      </div>
      <div class="pet-body">
        <div class="pet-top">
          <h3>${p.name}</h3>
          <span class="pet-price">${p.price}</span>
        </div>
        <p class="pet-sub">${p.breed} · ${p.sex} · ${p.age}</p>
        <div class="pet-tags">
          <span>${p.type==='dog'?'🐶 Chien':'🐱 Chat'}</span>
          <span>💉 ${p.health}</span>
        </div>
      </div>`;
    card.addEventListener('click', ()=> openModal(p.id));
    grid.appendChild(card);
  });
  observeReveal();
}

/* ===== Filtres ===== */
document.getElementById('filters').addEventListener('click', e=>{
  const chip = e.target.closest('.chip');
  if(!chip) return;
  document.querySelectorAll('.chip').forEach(c=> c.classList.remove('active'));
  chip.classList.add('active');
  renderPets(chip.dataset.filter);
});

/* ===== Modal ===== */
const modal = document.getElementById('modal');
let lastFocus = null;
function openModal(id){
  const p = pets.find(x=> x.id===id); if(!p) return;
  lastFocus = document.activeElement;
  const st = statusMap[p.status];
  document.getElementById('mMain').src = p.imgs[0];
  document.getElementById('mMain').onerror = function(){ imgFallback(this); };
  document.getElementById('mName').textContent = p.name;
  document.getElementById('mSub').textContent = `${p.breed} · ${p.sex} · ${p.age} · ${st.label}`;
  document.getElementById('mPrice').textContent = p.price;
  document.getElementById('mDesc').textContent = p.desc + ' ' + p.history;
  document.getElementById('mFacts').innerHTML = `
    <div class="fact"><small>Âge</small><b>${p.age}</b></div>
    <div class="fact"><small>Sexe</small><b>${p.sex}</b></div>
    <div class="fact"><small>Race</small><b>${p.breed}</b></div>
    <div class="fact"><small>Frais</small><b>${p.price}</b></div>`;
  document.getElementById('mVax').innerHTML = p.vax.map(v=>
    `<span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg>${v}</span>`).join('');
  const gal = document.getElementById('mGallery');
  gal.innerHTML = p.imgs.map((src,i)=>
    `<img src="${src}" alt="${p.name} ${i+1}" class="${i===0?'sel':''}" loading="lazy" onerror="imgFallback(this)">`).join('');
  gal.querySelectorAll('img').forEach(img=> img.addEventListener('click', ()=>{
    document.getElementById('mMain').src = img.src;
    gal.querySelectorAll('img').forEach(x=> x.classList.remove('sel'));
    img.classList.add('sel');
  }));
  modal.classList.add('open');
  document.body.style.overflow = 'hidden';
  document.getElementById('modalClose').focus();
}
function closeModal(){
  modal.classList.remove('open');
  document.body.style.overflow = '';
  if(lastFocus) lastFocus.focus();
}
document.getElementById('modalClose').addEventListener('click', closeModal);
document.getElementById('mContact').addEventListener('click', closeModal);
modal.addEventListener('click', e=>{ if(e.target===modal) closeModal(); });
addEventListener('keydown', e=>{ if(e.key==='Escape' && modal.classList.contains('open')) closeModal(); });

/* ===== Témoignages ===== */
const testimonials = [
  { stars:5, quote:"Adopter Gribouille a changé notre quotidien. L'équipe nous a écoutés et parfaitement orientés vers le chat qu'il nous fallait.", name:"Camille & Théo", role:"Ont adopté Gribouille", img:"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=120&q=80" },
  { stars:5, quote:"Un accompagnement humain du début à la fin. Notre Berger est en pleine forme et tellement câlin. Merci pour tout.", name:"Sophie M.", role:"A adopté Rocky", img:"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=120&q=80" },
  { stars:5, quote:"Tout était transparent : santé, caractère, conseils. On s'est sentis en confiance pour accueillir notre chaton.", name:"Karim B.", role:"A adopté Tigrou", img:"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=120&q=80" },
];
const track = document.getElementById('testiTrack');
const dots = document.getElementById('testiDots');
track.innerHTML = testimonials.map(t=>`
  <div class="testi-slide"><div class="testi-card">
    <div class="stars">${'<svg viewBox="0 0 24 24"><path d="M12 2l3 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.9 21l1.2-6.8-5-4.9 6.9-1z"/></svg>'.repeat(t.stars)}</div>
    <blockquote>“${t.quote}”</blockquote>
    <div class="testi-who">
      <img src="${t.img}" alt="${t.name}" onerror="imgFallback(this)">
      <div style="text-align:left"><b>${t.name}</b><small>${t.role}</small></div>
    </div>
  </div></div>`).join('');
dots.innerHTML = testimonials.map((_,i)=>`<button class="${i===0?'active':''}" aria-label="Témoignage ${i+1}"></button>`).join('');
let ti = 0;
const dotEls = [...dots.children];
function goTesti(n){
  ti = (n + testimonials.length) % testimonials.length;
  track.style.transform = `translateX(-${ti*100}%)`;
  dotEls.forEach((d,i)=> d.classList.toggle('active', i===ti));
}
dotEls.forEach((d,i)=> d.addEventListener('click', ()=>{ goTesti(i); restart(); }));
let timer = setInterval(()=> goTesti(ti+1), 5000);
function restart(){ clearInterval(timer); timer = setInterval(()=> goTesti(ti+1), 5000); }

/* ===== Reveal au scroll (Intersection Observer) ===== */
let io;
function observeReveal(){
  if(!io){
    io = new IntersectionObserver((entries)=>{
      entries.forEach(en=>{ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
    }, {threshold:.12, rootMargin:'0px 0px -40px 0px'});
  }
  document.querySelectorAll('.reveal:not(.in)').forEach(el=> io.observe(el));
}

/* ===== Compteur animé du hero ===== */
function countUp(el, target){
  let n = 0; const step = Math.ceil(target/45);
  const t = setInterval(()=>{ n += step; if(n>=target){ n=target; clearInterval(t); } el.textContent = n; }, 28);
}
const statEl = document.getElementById('statAnimals');
new IntersectionObserver((e,o)=>{ if(e[0].isIntersecting){ countUp(statEl, 142); o.disconnect(); } }).observe(statEl);

/* ===== Année footer ===== */
document.getElementById('year').textContent = new Date().getFullYear();

/* ===== PWA : service worker + popup d'installation ===== */
if('serviceWorker' in navigator){
  addEventListener('load', ()=> navigator.serviceWorker.register('service-worker.js').catch(()=>{}));
}
let deferredPrompt = null;
const installPop = document.getElementById('installPop');
const SNOOZE_KEY = 'installSnooze';
function canShowInstall(){
  const snooze = store.get(SNOOZE_KEY);
  return !snooze || Date.now() > Number(snooze);
}
addEventListener('beforeinstallprompt', (e)=>{
  e.preventDefault();
  deferredPrompt = e;
  if(canShowInstall()) setTimeout(()=> installPop.classList.add('show'), 3500);
});
document.getElementById('installYes').addEventListener('click', async ()=>{
  installPop.classList.remove('show');
  if(deferredPrompt){ deferredPrompt.prompt(); await deferredPrompt.userChoice; deferredPrompt = null; }
});
document.getElementById('installLater').addEventListener('click', ()=>{
  installPop.classList.remove('show');
  store.set(SNOOZE_KEY, String(Date.now() + 7*24*60*60*1000)); // ne plus afficher pendant 7 jours
});

/* ===== Init ===== */
renderPets('all');
observeReveal();
nav.classList.toggle('scrolled', scrollY > 24);
</script>
</body>
</html>
