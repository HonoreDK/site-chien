<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Seconde Chance — Refuge d'adoption pour chiens et chats</title>
<meta name="description" content="Adoptez un chien ou un chat près de chez vous. Découvrez nos compagnons disponibles, leurs frais d'adoption et contactez le refuge Seconde Chance.">
<meta name="theme-color" content="#FF7A59">

<!-- PWA -->
<link rel="manifest" href="manifest.json">
<link rel="icon" href="favicon.png" type="image/png">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Seconde Chance">

<!-- Open Graph -->
<meta property="og:title" content="Seconde Chance — Refuge d'adoption">
<meta property="og:description" content="Offrez une seconde chance à un compagnon de vie.">
<meta property="og:type" content="website">

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
/* ============================================================
   SECONDE CHANCE — refuge d'adoption
   Design tokens, glassmorphism, dark/light, micro-interactions
   ============================================================ */

:root{
  /* Marque */
  --primary: #FF7A59;
  --primary-strong: #F2613B;
  --secondary: #FFB347;

  /* Surfaces — mode clair (légèrement réchauffé, pas un slate froid) */
  --bg: #F8FAFC;
  --bg-warm: #FFF6F1;
  --card: #FFFFFF;
  --text: #0F172A;
  --muted: #5B6472;
  --line: rgba(15,23,42,.08);

  /* Verre */
  --glass: rgba(255,255,255,.62);
  --glass-strong: rgba(255,255,255,.78);
  --glass-border: rgba(255,255,255,.65);

  /* Ombres douces et superposées */
  --shadow-sm: 0 1px 2px rgba(15,23,42,.05), 0 4px 12px rgba(15,23,42,.05);
  --shadow-md: 0 8px 24px rgba(15,23,42,.08), 0 2px 6px rgba(15,23,42,.05);
  --shadow-lg: 0 24px 60px -18px rgba(242,97,59,.32), 0 10px 30px rgba(15,23,42,.10);
  --shadow-glow: 0 0 0 6px rgba(255,122,89,.14);

  --radius: 22px;
  --radius-lg: 30px;
  --maxw: 1180px;
  --ease: cubic-bezier(.22,.61,.36,1);
  --ease-back: cubic-bezier(.34,1.56,.64,1);
}

[data-theme="dark"]{
  --bg: #0B1120;
  --bg-warm: #0E1424;
  --card: #111827;
  --text: #F8FAFC;
  --muted: #9AA4B2;
  --line: rgba(255,255,255,.09);

  --glass: rgba(17,24,39,.55);
  --glass-strong: rgba(17,24,39,.72);
  --glass-border: rgba(255,255,255,.10);

  --shadow-sm: 0 1px 2px rgba(0,0,0,.4), 0 6px 16px rgba(0,0,0,.35);
  --shadow-md: 0 10px 30px rgba(0,0,0,.45);
  --shadow-lg: 0 28px 70px -20px rgba(0,0,0,.7), 0 10px 30px rgba(0,0,0,.4);
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

body{
  font-family:"Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
  transition:background .5s var(--ease), color .5s var(--ease);
}

/* Halos d'ambiance chaleureux en arrière-plan */
body::before{
  content:"";
  position:fixed; inset:0; z-index:-2;
  background:
    radial-gradient(60% 50% at 12% 8%, rgba(255,179,71,.20), transparent 60%),
    radial-gradient(55% 45% at 92% 4%, rgba(255,122,89,.22), transparent 60%),
    radial-gradient(70% 60% at 50% 110%, rgba(255,122,89,.14), transparent 60%);
  transition:opacity .6s var(--ease);
}
[data-theme="dark"] body::before{opacity:.5}

h1,h2,h3,h4,.display{font-family:"Bricolage Grotesque", system-ui, sans-serif; font-weight:700; letter-spacing:-.02em; line-height:1.05}
a{color:inherit; text-decoration:none}
img{display:block; max-width:100%}
section{padding:clamp(64px,9vw,120px) 0}
.wrap{width:min(var(--maxw), 92vw); margin-inline:auto}

.eyebrow{
  display:inline-flex; align-items:center; gap:8px;
  font-size:.78rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
  color:var(--primary-strong);
}
.eyebrow::before{content:""; width:22px; height:2px; border-radius:2px; background:var(--primary)}

.section-head{max-width:640px; margin-bottom:clamp(36px,5vw,56px)}
.section-head h2{font-size:clamp(2rem,4.4vw,3.1rem); margin:14px 0 12px}
.section-head p{color:var(--muted); font-size:1.06rem}

/* ===== Boutons ===== */
.btn{
  --c:#fff;
  display:inline-flex; align-items:center; justify-content:center; gap:9px;
  font-family:inherit; font-weight:700; font-size:1rem;
  padding:14px 26px; border-radius:999px; border:none; cursor:pointer;
  transition:transform .25s var(--ease-back), box-shadow .25s var(--ease), background .25s;
  white-space:nowrap;
}
.btn:active{transform:scale(.96)}
.btn-primary{
  color:#fff;
  background:linear-gradient(135deg, var(--primary), var(--secondary));
  box-shadow:0 10px 26px -8px rgba(242,97,59,.6);
}
.btn-primary:hover{transform:translateY(-2px); box-shadow:0 16px 34px -8px rgba(242,97,59,.7)}
.btn-ghost{
  color:var(--text);
  background:var(--glass);
  border:1px solid var(--glass-border);
  -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px);
}
.btn-ghost:hover{transform:translateY(-2px); box-shadow:var(--shadow-md)}

/* ===== Navbar ===== */
.nav{
  position:fixed; inset:14px 0 auto 0; z-index:90;
  display:flex; justify-content:center; pointer-events:none;
  transition:inset .4s var(--ease);
}
.nav-inner{
  pointer-events:auto;
  width:min(var(--maxw), 94vw);
  display:flex; align-items:center; justify-content:space-between; gap:18px;
  padding:11px 14px 11px 18px;
  border-radius:999px;
  background:transparent;
  border:1px solid transparent;
  transition:background .4s var(--ease), border-color .4s var(--ease),
             box-shadow .4s var(--ease), padding .4s var(--ease);
}
.nav.scrolled .nav-inner{
  background:var(--glass-strong);
  border-color:var(--glass-border);
  -webkit-backdrop-filter:blur(20px) saturate(160%); backdrop-filter:blur(20px) saturate(160%);
  box-shadow:var(--shadow-md);
}
.brand{display:flex; align-items:center; gap:11px; font-family:"Bricolage Grotesque"; font-weight:800; font-size:1.16rem; letter-spacing:-.02em}
.brand .mark{
  width:38px; height:38px; border-radius:12px; flex:none;
  display:grid; place-items:center;
  background:linear-gradient(135deg, var(--primary), var(--secondary));
  box-shadow:0 6px 16px -4px rgba(242,97,59,.6);
  transition:transform .5s var(--ease-back);
}
.brand:hover .mark{transform:rotate(-12deg) scale(1.08)}
.brand .mark svg{width:22px; height:22px}
.nav-links{display:flex; align-items:center; gap:4px}
.nav-links a{
  font-weight:600; font-size:.95rem; color:var(--muted);
  padding:9px 14px; border-radius:999px; position:relative;
  transition:color .25s, background .25s;
}
.nav-links a:hover{color:var(--text); background:var(--line)}
.nav-actions{display:flex; align-items:center; gap:8px}

.icon-btn{
  width:42px; height:42px; flex:none; border-radius:50%;
  display:grid; place-items:center; cursor:pointer;
  background:var(--glass); border:1px solid var(--glass-border);
  -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px);
  color:var(--text);
  transition:transform .35s var(--ease-back), box-shadow .25s, background .25s;
}
.icon-btn:hover{transform:translateY(-2px) rotate(8deg); box-shadow:var(--shadow-md)}
.icon-btn svg{width:20px; height:20px}
.theme-btn .moon{display:none}
[data-theme="dark"] .theme-btn .sun{display:none}
[data-theme="dark"] .theme-btn .moon{display:block}

.burger{display:none}

/* ===== Hero ===== */
.hero{position:relative; padding-top:clamp(120px,18vh,180px); padding-bottom:clamp(60px,8vw,90px); overflow:hidden}
.hero-grid{display:grid; grid-template-columns:1.05fr .95fr; gap:clamp(28px,5vw,64px); align-items:center}
.hero-copy{max-width:560px}
.hero h1{font-size:clamp(2.6rem,6.2vw,4.6rem); font-weight:800; margin:18px 0}
.hero h1 .accent{
  background:linear-gradient(120deg, var(--primary), var(--secondary));
  -webkit-background-clip:text; background-clip:text; color:transparent;
}
.hero p.lead{font-size:clamp(1.05rem,2.2vw,1.28rem); color:var(--muted); margin-bottom:30px}
.hero-cta{display:flex; flex-wrap:wrap; gap:14px}
.hero-stats{display:flex; gap:28px; margin-top:38px; flex-wrap:wrap}
.hero-stats .stat strong{font-family:"Bricolage Grotesque"; font-size:1.7rem; display:block; line-height:1}
.hero-stats .stat span{font-size:.86rem; color:var(--muted)}

/* Visuel hero : collage de cartes flottantes en verre */
.hero-visual{position:relative; height:clamp(360px,46vw,520px)}
.hero-photo{
  position:absolute; inset:0; border-radius:var(--radius-lg); overflow:hidden;
  box-shadow:var(--shadow-lg);
}
.hero-photo img{width:100%; height:100%; object-fit:cover}
.float-card{
  position:absolute; padding:14px 16px; border-radius:18px;
  background:var(--glass-strong); border:1px solid var(--glass-border);
  -webkit-backdrop-filter:blur(16px) saturate(150%); backdrop-filter:blur(16px) saturate(150%);
  box-shadow:var(--shadow-md);
  display:flex; align-items:center; gap:11px;
  animation:floaty 6s var(--ease) infinite;
}
.float-card .fc-ico{width:40px; height:40px; border-radius:12px; display:grid; place-items:center; flex:none; color:#fff}
.float-card b{display:block; font-family:"Bricolage Grotesque"; font-size:1.05rem; line-height:1.1}
.float-card small{color:var(--muted); font-size:.78rem}
.fc-1{top:8%; left:-6%; animation-delay:0s}
.fc-1 .fc-ico{background:linear-gradient(135deg,#22C55E,#16A34A)}
.fc-2{bottom:10%; right:-7%; animation-delay:1.6s}
.fc-2 .fc-ico{background:linear-gradient(135deg,var(--primary),var(--secondary))}
@keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

/* ===== Filtres + grille animaux ===== */
.filters{display:flex; flex-wrap:wrap; gap:10px; margin-bottom:34px}
.chip{
  font-family:inherit; font-weight:600; font-size:.92rem; cursor:pointer;
  padding:9px 18px; border-radius:999px;
  background:var(--card); border:1px solid var(--line); color:var(--muted);
  transition:all .25s var(--ease);
}
.chip:hover{color:var(--text); border-color:var(--primary)}
.chip.active{
  color:#fff; border-color:transparent;
  background:linear-gradient(135deg,var(--primary),var(--secondary));
  box-shadow:0 8px 20px -8px rgba(242,97,59,.6);
}

.grid{display:grid; grid-template-columns:repeat(auto-fill, minmax(280px,1fr)); gap:24px}

.pet-card{
  background:var(--card); border:1px solid var(--line);
  border-radius:var(--radius); overflow:hidden; cursor:pointer;
  box-shadow:var(--shadow-sm);
  transition:transform .4s var(--ease), box-shadow .4s var(--ease), border-color .4s;
  transform-style:preserve-3d;
}
.pet-card:hover{transform:translateY(-8px); box-shadow:var(--shadow-lg); border-color:transparent}
.pet-media{position:relative; aspect-ratio:4/3.2; overflow:hidden; background:linear-gradient(135deg,var(--primary),var(--secondary))}
.pet-media img{width:100%; height:100%; object-fit:cover; transition:transform .7s var(--ease)}
.pet-card:hover .pet-media img{transform:scale(1.08)}
.pet-badge{
  position:absolute; top:12px; left:12px; z-index:2;
  font-size:.72rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase;
  padding:6px 12px; border-radius:999px; color:#fff;
  -webkit-backdrop-filter:blur(6px); backdrop-filter:blur(6px);
}
.b-dispo{background:rgba(34,197,94,.92)}
.b-reserve{background:rgba(100,116,139,.92)}
.b-nouveau{background:linear-gradient(135deg,var(--primary),var(--secondary))}
.pet-fav{
  position:absolute; top:10px; right:10px; z-index:2;
  width:38px; height:38px; border-radius:50%; border:none; cursor:pointer;
  display:grid; place-items:center;
  background:rgba(255,255,255,.85); -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px);
  box-shadow:var(--shadow-sm); transition:transform .3s var(--ease-back);
}
.pet-fav:hover{transform:scale(1.12)}
.pet-fav svg{width:20px; height:20px; fill:none; stroke:#94A3B8; stroke-width:2; transition:.2s}
.pet-fav.on svg{fill:var(--primary); stroke:var(--primary)}
.pet-body{padding:18px 18px 20px}
.pet-top{display:flex; justify-content:space-between; align-items:baseline; gap:10px}
.pet-top h3{font-size:1.32rem}
.pet-price{font-family:"Bricolage Grotesque"; font-weight:800; color:var(--primary-strong); font-size:1.18rem; white-space:nowrap}
.pet-sub{color:var(--muted); font-size:.92rem; margin-top:2px}
.pet-tags{display:flex; flex-wrap:wrap; gap:7px; margin-top:14px}
.pet-tags span{
  font-size:.78rem; font-weight:600; color:var(--muted);
  padding:5px 10px; border-radius:8px; background:var(--bg-warm); border:1px solid var(--line);
}
[data-theme="dark"] .pet-tags span{background:rgba(255,255,255,.04)}

/* ===== Modal détails ===== */
.modal-backdrop{
  position:fixed; inset:0; z-index:120; display:none;
  align-items:center; justify-content:center; padding:18px;
  background:rgba(8,12,22,.55);
  -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px);
  opacity:0; transition:opacity .35s var(--ease);
}
.modal-backdrop.open{display:flex; opacity:1}
.modal{
  width:min(820px, 96vw); max-height:90vh; overflow:auto;
  background:var(--card); border:1px solid var(--glass-border);
  border-radius:var(--radius-lg); box-shadow:var(--shadow-lg);
  transform:scale(.92) translateY(14px); opacity:0;
  transition:transform .4s var(--ease-back), opacity .35s var(--ease);
}
.modal-backdrop.open .modal{transform:scale(1) translateY(0); opacity:1}
.modal::-webkit-scrollbar{width:8px}
.modal::-webkit-scrollbar-thumb{background:var(--line); border-radius:8px}
.modal-hero{position:relative; aspect-ratio:16/8; overflow:hidden; background:linear-gradient(135deg,var(--primary),var(--secondary))}
.modal-hero img{width:100%; height:100%; object-fit:cover}
.modal-close{
  position:absolute; top:14px; right:14px; z-index:3;
  width:42px; height:42px; border-radius:50%; border:none; cursor:pointer;
  background:rgba(255,255,255,.9); display:grid; place-items:center;
  box-shadow:var(--shadow-sm); transition:transform .3s var(--ease-back);
}
.modal-close:hover{transform:rotate(90deg)}
.gallery{display:flex; gap:10px; padding:14px 22px 0; overflow-x:auto}
.gallery img{width:92px; height:72px; flex:none; object-fit:cover; border-radius:12px; cursor:pointer; border:2px solid transparent; transition:.25s}
.gallery img:hover,.gallery img.sel{border-color:var(--primary)}
.modal-body{padding:22px}
.modal-body .pet-top h3{font-size:1.9rem}
.modal-body .desc{color:var(--muted); margin:14px 0 20px}
.facts{display:grid; grid-template-columns:repeat(auto-fit,minmax(130px,1fr)); gap:12px; margin-bottom:22px}
.fact{padding:13px 15px; border-radius:14px; background:var(--bg-warm); border:1px solid var(--line)}
[data-theme="dark"] .fact{background:rgba(255,255,255,.03)}
.fact small{display:block; color:var(--muted); font-size:.74rem; text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px}
.fact b{font-family:"Bricolage Grotesque"; font-size:1.02rem}
.vax{display:flex; flex-wrap:wrap; gap:8px; margin-bottom:24px}
.vax span{display:inline-flex; align-items:center; gap:6px; font-size:.85rem; font-weight:600; color:#16A34A; background:rgba(34,197,94,.12); padding:6px 12px; border-radius:999px}
.vax span svg{width:15px; height:15px}
.modal-cta{display:flex; gap:12px; flex-wrap:wrap}

/* ===== Tarifs ===== */
.price-grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:22px}
.price-card{
  position:relative; padding:30px 26px; border-radius:var(--radius);
  background:var(--card); border:1px solid var(--line); box-shadow:var(--shadow-sm);
  transition:transform .4s var(--ease), box-shadow .4s var(--ease);
}
.price-card:hover{transform:translateY(-6px); box-shadow:var(--shadow-lg)}
.price-card.feat{
  background:linear-gradient(160deg, rgba(255,122,89,.10), var(--card));
  border-color:rgba(255,122,89,.4);
}
.price-card .pc-ico{font-size:1.7rem; margin-bottom:14px}
.price-card h3{font-size:1.18rem; margin-bottom:6px}
.price-card .amount{font-family:"Bricolage Grotesque"; font-weight:800; font-size:2.6rem; line-height:1; margin:8px 0 4px}
.price-card .amount span{font-size:1rem; font-weight:600; color:var(--muted)}
.price-card ul{list-style:none; margin-top:18px; display:grid; gap:10px}
.price-card li{display:flex; gap:9px; font-size:.92rem; color:var(--muted)}
.price-card li svg{width:18px; height:18px; flex:none; color:var(--primary); margin-top:2px}

/* ===== Témoignages ===== */
.testi{position:relative; overflow:hidden}
.testi-track{display:flex; transition:transform .6s var(--ease)}
.testi-slide{flex:0 0 100%; padding:6px}
.testi-card{
  max-width:760px; margin-inline:auto; text-align:center;
  padding:clamp(30px,5vw,52px); border-radius:var(--radius-lg);
  background:var(--glass-strong); border:1px solid var(--glass-border);
  -webkit-backdrop-filter:blur(18px); backdrop-filter:blur(18px);
  box-shadow:var(--shadow-md);
}
.stars{display:flex; gap:4px; justify-content:center; margin-bottom:18px; color:var(--secondary)}
.stars svg{width:22px; height:22px; fill:currentColor}
.testi-card blockquote{font-family:"Bricolage Grotesque"; font-weight:600; font-size:clamp(1.2rem,2.6vw,1.7rem); line-height:1.35; letter-spacing:-.01em}
.testi-who{display:flex; align-items:center; gap:13px; justify-content:center; margin-top:26px}
.testi-who img{width:52px; height:52px; border-radius:50%; object-fit:cover; border:2px solid var(--primary)}
.testi-who b{display:block}
.testi-who small{color:var(--muted)}
.testi-dots{display:flex; gap:9px; justify-content:center; margin-top:28px}
.testi-dots button{width:9px; height:9px; border-radius:50%; border:none; cursor:pointer; background:var(--line); transition:.3s}
.testi-dots button.active{width:28px; border-radius:999px; background:var(--primary)}

/* ===== Contact ===== */
.contact-grid{display:grid; grid-template-columns:1.1fr .9fr; gap:28px; align-items:stretch}
.contact-card{
  padding:clamp(26px,4vw,40px); border-radius:var(--radius-lg);
  background:var(--card); border:1px solid var(--line); box-shadow:var(--shadow-md);
}
.contact-list{display:grid; gap:18px; margin-top:22px}
.contact-item{display:flex; gap:15px; align-items:flex-start}
.contact-item .ci-ico{
  width:46px; height:46px; border-radius:14px; flex:none; display:grid; place-items:center; color:#fff;
  background:linear-gradient(135deg,var(--primary),var(--secondary));
}
.contact-item .ci-ico svg{width:22px; height:22px}
.contact-item small{color:var(--muted); font-size:.82rem}
.contact-item b{font-size:1.05rem}
.socials{display:flex; gap:10px; margin-top:26px}
.socials a{width:44px; height:44px; border-radius:12px; display:grid; place-items:center; background:var(--bg-warm); border:1px solid var(--line); color:var(--text); transition:.3s var(--ease-back)}
[data-theme="dark"] .socials a{background:rgba(255,255,255,.04)}
.socials a:hover{transform:translateY(-3px); color:#fff; background:linear-gradient(135deg,var(--primary),var(--secondary)); border-color:transparent}
.socials a svg{width:20px; height:20px}
.contact-side{
  border-radius:var(--radius-lg); overflow:hidden; position:relative;
  background:linear-gradient(160deg,var(--primary),var(--secondary));
  color:#fff; padding:clamp(26px,4vw,40px); display:flex; flex-direction:column; justify-content:center;
  box-shadow:var(--shadow-lg);
}
.contact-side h3{color:#fff; font-size:1.6rem; margin-bottom:10px}
.contact-side p{opacity:.92; margin-bottom:22px}
.contact-side .btn{background:#fff; color:var(--primary-strong)}
.hours{margin-top:26px; display:grid; gap:8px; font-size:.92rem}
.hours div{display:flex; justify-content:space-between; padding-bottom:8px; border-bottom:1px solid rgba(255,255,255,.2)}

/* ===== Footer ===== */
footer{padding:60px 0 36px; border-top:1px solid var(--line); margin-top:20px}
.foot-grid{display:grid; grid-template-columns:1.5fr 1fr 1fr; gap:34px; margin-bottom:38px}
.foot-grid p{color:var(--muted); font-size:.94rem; margin-top:12px; max-width:320px}
.foot-col h4{font-size:.82rem; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); margin-bottom:14px}
.foot-col a{display:block; color:var(--text); padding:6px 0; font-size:.95rem; opacity:.85; transition:.2s}
.foot-col a:hover{opacity:1; color:var(--primary); transform:translateX(3px)}
.foot-bottom{display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; padding-top:24px; border-top:1px solid var(--line); color:var(--muted); font-size:.88rem}

/* ===== Messenger flottant ===== */
.messenger{
  position:fixed; bottom:24px; right:24px; z-index:80;
  width:60px; height:60px; border-radius:50%; display:grid; place-items:center;
  background:linear-gradient(135deg,#0A7CFF,#A21CF0); color:#fff;
  box-shadow:0 12px 30px -6px rgba(10,124,255,.6);
  animation:mpulse 2.6s infinite;
  transition:transform .3s var(--ease-back);
}
.messenger:hover{transform:scale(1.1)}
.messenger svg{width:30px; height:30px}
.messenger::after{
  content:"Discutez avec nous"; position:absolute; right:74px; white-space:nowrap;
  background:var(--card); color:var(--text); font-size:.85rem; font-weight:600;
  padding:9px 14px; border-radius:12px; box-shadow:var(--shadow-md); border:1px solid var(--line);
  opacity:0; transform:translateX(8px); pointer-events:none; transition:.3s var(--ease);
}
.messenger:hover::after{opacity:1; transform:translateX(0)}
@keyframes mpulse{
  0%{box-shadow:0 12px 30px -6px rgba(10,124,255,.6), 0 0 0 0 rgba(10,124,255,.5)}
  70%{box-shadow:0 12px 30px -6px rgba(10,124,255,.6), 0 0 0 18px rgba(10,124,255,0)}
  100%{box-shadow:0 12px 30px -6px rgba(10,124,255,.6), 0 0 0 0 rgba(10,124,255,0)}
}

/* ===== Popup installation PWA ===== */
.install-pop{
  position:fixed; left:50%; bottom:24px; transform:translate(-50%, 160%);
  z-index:100; width:min(440px, 92vw);
  display:flex; align-items:center; gap:16px;
  padding:18px; border-radius:22px;
  background:var(--glass-strong); border:1px solid var(--glass-border);
  -webkit-backdrop-filter:blur(22px) saturate(160%); backdrop-filter:blur(22px) saturate(160%);
  box-shadow:var(--shadow-lg);
  transition:transform .55s var(--ease-back);
}
.install-pop.show{transform:translate(-50%, 0)}
.install-pop .ip-ico{width:54px; height:54px; border-radius:16px; flex:none}
.install-pop b{font-family:"Bricolage Grotesque"; font-size:1.05rem; display:block; line-height:1.2}
.install-pop small{color:var(--muted); font-size:.85rem}
.install-pop .ip-actions{display:flex; gap:8px; margin-top:10px}
.install-pop .ip-actions .btn{padding:9px 16px; font-size:.88rem}
.ip-later{background:transparent; border:1px solid var(--line); color:var(--muted)}

/* ===== Reveal au scroll ===== */
.reveal{opacity:0; transform:translateY(28px); transition:opacity .7s var(--ease), transform .7s var(--ease)}
.reveal.in{opacity:1; transform:none}
.reveal.r-left{transform:translateX(-32px)} .reveal.r-left.in{transform:none}
.reveal.r-scale{transform:scale(.94)} .reveal.r-scale.in{transform:none}
[data-d="1"]{transition-delay:.08s}[data-d="2"]{transition-delay:.16s}
[data-d="3"]{transition-delay:.24s}[data-d="4"]{transition-delay:.32s}

/* ===== Responsive ===== */
@media (max-width:920px){
  .hero-grid{grid-template-columns:1fr; text-align:center}
  .hero-copy{margin-inline:auto}
  .hero-cta,.hero-stats{justify-content:center}
  .hero-visual{height:clamp(320px,70vw,420px); margin-top:8px}
  .contact-grid{grid-template-columns:1fr}
  .foot-grid{grid-template-columns:1fr 1fr}
}
@media (max-width:680px){
  .nav-links{
    position:absolute; top:64px; right:0; left:0;
    flex-direction:column; gap:4px; padding:14px;
    background:var(--glass-strong); -webkit-backdrop-filter:blur(20px); backdrop-filter:blur(20px);
    border:1px solid var(--glass-border); border-radius:20px; box-shadow:var(--shadow-lg);
    transform:translateY(-12px); opacity:0; pointer-events:none; transition:.3s var(--ease);
  }
  .nav-links.open{transform:none; opacity:1; pointer-events:auto}
  .nav-links a{width:100%}
  .burger{display:grid}
  .foot-grid{grid-template-columns:1fr}
  .fc-1,.fc-2{display:none}
  section{padding:64px 0}
}

@media (prefers-reduced-motion:reduce){
  *{animation-duration:.001ms !important; transition-duration:.001ms !important}
  html{scroll-behavior:auto}
}
:focus-visible{outline:3px solid var(--primary); outline-offset:3px; border-radius:6px}
</style>
